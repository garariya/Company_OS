generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
  EMPLOYEE
}


model User {
  id          Int     @id @default(autoincrement())
  firstName   String
  middleName  String?
  lastName    String
  email       String @unique
  password    String
  role        Role @default(EMPLOYEE)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}